	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/award> ;
	skos:broader	trustindicator:partyInfo .

trustindicator:organisationInfo
	rdf:type skos:Concept ;
	skos:prefLabel	"organisation info"@en-GB ;
	skos:definition	"Information about the news organisation or journalist's history and background"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
