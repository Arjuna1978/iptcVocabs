<http://cv.iptc.org/newscodes/trustindicator/> 
	rdf:type skos:ConceptScheme ; 
  ikos:prefSchemeAlias "trustindicator" ;
  ikos:authority "http://www.iptc.org" ;
  dct:rightsHolder "IPTC, International Press Telecommunications Council - https://iptc.org" ;
  ikos:licenceLink "http://creativecommons.org/licenses/by/4.0/" ;
  ikos:dateReleased "2025-09-30T12:00:00+00:00"^^xsd:dateTime ;
  dct:dateSubmitted "2025-09-30T12:00:00+00:00"^^xsd:dateTime ;
  skos:prefLabel "Trust Indicator"@en-GB ;
  skos:definition "Indicators showing how a news organisation works to encourage readers to consider the news organisation worthy of their trust"@en-GB ;
  skos:note "This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:hasTopConcept		trustindicator:editorialPolicy ;
	skos:hasTopConcept		trustindicator:partyInfo ;
	skos:hasTopConcept		trustindicator:pieceOfWorkInfo .

trustindicator:editorialPolicy
	rdf:type skos:Concept ;
	skos:prefLabel	"editorial policy"@en-GB ;
	skos:definition	"A statement describing the journalistic standards of behaviour expected by the organisation"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/publishingPrinciples> ;
	skos:narrower	trustindicator:feedbackPolicy ;
	skos:narrower	trustindicator:correctionsPolicy ;
	skos:narrower	trustindicator:editorialDiversityPolicy ;
	skos:narrower	trustindicator:ethicsPolicy ;
	skos:narrower	trustindicator:coveragePolicy ;
	skos:narrower	trustindicator:noBylinesPolicy ;
	skos:narrower	trustindicator:unnamedSourcesPolicy ;
	skos:narrower	trustindicator:factCheckingPolicy .

trustindicator:feedbackPolicy
	rdf:type skos:Concept ;
	skos:prefLabel	"feedback policy"@en-GB ;
	skos:definition	"A statement about how a newsroom involves the public in coverage decisions, reporting and activities after publication"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/actionableFeedbackPolicy> ;
	skos:broader	trustindicator:editorialPolicy .

trustindicator:correctionsPolicy
	rdf:type skos:Concept ;
	skos:prefLabel	"corrections policy"@en-GB ;
	skos:definition	"A statement describing a newsroom's disclosure and correction policy regarding errors"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/correctionsPolicy> ;
	skos:broader	trustindicator:editorialPolicy .

trustindicator:editorialDiversityPolicy
	rdf:type skos:Concept ;
	skos:prefLabel	"editorial diversity policy"@en-GB ;
	skos:definition	"An organisation's policy describing diversity of editorial sources"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broadMatch <https://schema.org/diversityPolicy> ;
	skos:broader	trustindicator:editorialPolicy .

trustindicator:ethicsPolicy
	rdf:type skos:Concept ;
	skos:prefLabel	"ethics policy"@en-GB ;
	skos:definition	"Statement about a news organisation's ethics policy, e.g. regarding journalistic and publishing practices"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2020-09-24T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2020-09-24T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/ethicsPolicy> ;
	skos:broader	trustindicator:editorialPolicy .

trustindicator:coveragePolicy
	rdf:type skos:Concept ;
	skos:prefLabel	"coverage policy"@en-GB ;
	skos:definition	"A statement on coverage priorities, including any public agenda or stance on issues"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/missionCoveragePrioritiesPolicy> ;
	skos:broader	trustindicator:editorialPolicy .

trustindicator:noBylinesPolicy
	rdf:type skos:Concept ;
	skos:prefLabel	"no bylines policy"@en-GB ;
	skos:definition	"A statement explaining when authors of articles are not named in bylines"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/noBylinesPolicy> ;
	skos:broader	trustindicator:editorialPolicy .

trustindicator:unnamedSourcesPolicy
	rdf:type skos:Concept ;
	skos:prefLabel	"unnamed sources policy"@en-GB ;
	skos:definition	"A statement about policy on use of unnamed sources and the decision process required."@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/unnamedSourcesPolicy> ;
	skos:broader	trustindicator:editorialPolicy .

trustindicator:factCheckingPolicy
	rdf:type skos:Concept ;
	skos:prefLabel	"fact checking policy"@en-GB ;
	skos:definition	"Disclosure about verification and fact-checking processes for a news media organisation"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/verificationFactCheckingPolicy> ;
	skos:broader	trustindicator:editorialPolicy .

trustindicator:partyInfo
	rdf:type skos:Concept ;
	skos:prefLabel	"party info"@en-GB ;
	skos:definition	"Information about a party that produces news content (either a person or an organisation)"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:narrower	trustindicator:archive ;
	skos:narrower	trustindicator:award ;
	skos:narrower	trustindicator:organisationInfo ;
	skos:narrower	trustindicator:journalistInfo ;
	skos:narrower	trustindicator:knowsLanguage ;
	skos:narrower	trustindicator:knowsAbout .

trustindicator:archive
	rdf:type skos:Concept ;
	skos:prefLabel	"archive"@en-GB ;
	skos:definition	"A list of the journalist or news organisation's work in reverse chronological order, sometimes including a search option"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broader	trustindicator:partyInfo .

trustindicator:award
	rdf:type skos:Concept ;
	skos:prefLabel	"award"@en-GB ;
	skos:definition	"A list of the honours or awards received by the journalist or news organisation"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
