	skos:narrower	trustindicator:diversityStaffingReport ;
	skos:narrower	trustindicator:seniorEditorialStaff ;
	skos:narrower	trustindicator:ownershipFundingInfo .

trustindicator:organisationDiversityPolicy
	rdf:type skos:Concept ;
	skos:prefLabel	"organisation diversity policy"@en-GB ;
	skos:definition	"Statement on the organisation's staff diversity policy, optionally providing staffing data"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broadMatch <https://schema.org/diversityPolicy> ;
	skos:broader	trustindicator:organisationInfo .

trustindicator:diversityStaffingReport
	rdf:type skos:Concept ;
	skos:prefLabel	"diversity staffing report"@en-GB ;
	skos:definition	"A report on staffing diversity issues. In a news context this might be for example ASNE or RTDNA (US) reports, or self-reported."@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/diversityStaffingReport> ;
	skos:broader	trustindicator:organisationInfo .

trustindicator:seniorEditorialStaff
	rdf:type skos:Concept ;
	skos:prefLabel	"senior editorial staff"@en-GB ;
	skos:definition	"Information about a news outlet's senior editorial staff, sometimes known as the masthead"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/masthead> ;
	skos:broader	trustindicator:organisationInfo .

trustindicator:ownershipFundingInfo
	rdf:type skos:Concept ;
	skos:prefLabel	"ownership and funding information"@en-GB ;
	skos:definition	"A description of organizational ownership structure, funding and grants, with particular reference to editorial independence"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:exactMatch <https://schema.org/ownershipFundingInfo> ;
	skos:broader	trustindicator:organisationInfo .

trustindicator:journalistInfo
	rdf:type skos:Concept ;
	skos:prefLabel	"journalist info"@en-GB ;
	skos:definition	"Link to the journalist's site-level profile page. This is typically included in each individual piece of content by that journalist."@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broader	trustindicator:partyInfo ;
	skos:narrower	trustindicator:biography ;
	skos:narrower	trustindicator:journalistImage .

trustindicator:biography
	rdf:type skos:Concept ;
	skos:prefLabel	"biography"@en-GB ;
	skos:definition	"Brief journalistic biography. Can include previous employers, education, outside interests, commitments associated with ethics (such as voting, community involvement). According to the Trust Project, biography must include any affiliations that may pose a conflict of interest and how this is handled. A biography's length is not necessarily an indicator of trustworthiness."@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broader	trustindicator:journalistInfo .

trustindicator:journalistImage
	rdf:type skos:Concept ;
	skos:prefLabel	"journalist image"@en-GB ;
	skos:definition	"Link to photograph or image of the journalist that created a piece of editorial content"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broadMatch <https://schema.org/image> ;
	skos:broader	trustindicator:journalistInfo .

trustindicator:knowsLanguage
	rdf:type skos:Concept ;
	skos:prefLabel	"knows language"@en-GB ;
	skos:definition	"Indicates knowledge of a human language. The presence of this indicator does not distinguish skill levels or reading/writing/speaking/signing. Language codes should be taken from the IETF BCP 47 standard."@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broadMatch <https://schema.org/knowsLanguage> ;
	skos:broader	trustindicator:partyInfo .

trustindicator:knowsAbout
	rdf:type skos:Concept ;
	skos:prefLabel	"knows about"@en-GB ;
	skos:definition	"Indicates a topic that is known about, suggesting possible expertise without distinguishing skill level"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broadMatch <https://schema.org/knowsAbout> ;
	skos:broader	trustindicator:partyInfo .

trustindicator:pieceOfWorkInfo
	rdf:type skos:Concept ;
	skos:prefLabel	"piece of work info"@en-GB ;
	skos:definition	"Trust information that applies to a particular piece of journalistic work, such as references or sources"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:narrower	trustindicator:correctedByResource ;
	skos:narrower	trustindicator:correctsResource ;
	skos:narrower	trustindicator:externalSourceMaterials ;
	skos:narrower	trustindicator:internalSourceMaterials ;
	skos:narrower	trustindicator:secondarySources .

trustindicator:correctedByResource
	rdf:type skos:Concept ;
	skos:prefLabel	"corrected by resource"@en-GB ;
	skos:definition	"Indicates an update to a journalistic work via a link to another document that corrects this document"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broadMatch <https://schema.org/correction> ;
	skos:broader	trustindicator:pieceOfWorkInfo .

trustindicator:correctsResource
	rdf:type skos:Concept ;
	skos:prefLabel	"corrects resource"@en-GB ;
	skos:definition	"Indicates that this news item corrects the referenced news item"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broadMatch <https://schema.org/CorrectionComment> ;
	skos:broader	trustindicator:pieceOfWorkInfo .

trustindicator:externalSourceMaterials
	rdf:type skos:Concept ;
	skos:prefLabel	"external source materials"@en-GB ;
	skos:definition	"External material that this news item is based on, such as a press release or parliamentary record"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broadMatch <https://schema.org/isBasedOn> ;
	skos:broader	trustindicator:pieceOfWorkInfo .

trustindicator:internalSourceMaterials
	rdf:type skos:Concept ;
	skos:prefLabel	"internal source materials"@en-GB ;
	skos:definition	"Indicates journalistic materials used to create this news item, such as interview transcripts or data analysis"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broadMatch <http://pending.schema.org/backstory> ;
	skos:broader	trustindicator:pieceOfWorkInfo .

trustindicator:secondarySources
	rdf:type skos:Concept ;
	skos:prefLabel	"secondary sources"@en-GB ;
	skos:definition	"Indicator of an external source that this news item is based on, such as an existing news report elsewhere in the media"@en-GB ;
	skos:note	"This vocabulary was created through IPTC's adoption of The Trust Project's Trust Indicators® and collaboration with the Journalism Trust Initiative"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/trustindicator/>  ;
	ikos:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-19T12:00:00+00:00"^^xsd:dateTime  ;
	skos:broadMatch <https://schema.org/isBasedOn> ;
	skos:broader	trustindicator:pieceOfWorkInfo .
