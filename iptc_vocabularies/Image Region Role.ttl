<http://cv.iptc.org/newscodes/imageregionrole/> 
	rdf:type skos:ConceptScheme ; 
  ikos:prefSchemeAlias "imgregrole" ;
  ikos:authority "http://www.iptc.org" ;
  dct:rightsHolder "IPTC, International Press Telecommunications Council - https://iptc.org" ;
  ikos:licenceLink "http://creativecommons.org/licenses/by/4.0/" ;
  ikos:dateReleased "2025-03-31T12:00:00+00:00"^^xsd:dateTime ;
  dct:dateSubmitted "2025-03-31T12:00:00+00:00"^^xsd:dateTime ;
  skos:prefLabel "Image Region Role"@en-GB ;
  skos:definition "Role of an image region among other image regions of the same image or other images"@en-GB ;
	skos:hasTopConcept		imgregrole:cropping ;
	skos:hasTopConcept		imgregrole:recomCropping ;
	skos:hasTopConcept		imgregrole:landscapeCropping ;
	skos:hasTopConcept		imgregrole:portraitCropping ;
	skos:hasTopConcept		imgregrole:squareCropping ;
	skos:hasTopConcept		imgregrole:compositeImageItem ;
	skos:hasTopConcept		imgregrole:copyrightRegion ;
	skos:hasTopConcept		imgregrole:subjectArea ;
	skos:hasTopConcept		imgregrole:mainSubjectArea ;
	skos:hasTopConcept		imgregrole:areaOfInterest ;
	skos:hasTopConcept		imgregrole:anonymised ;
	skos:hasTopConcept		imgregrole:recommendedAnonymisation ;
	skos:hasTopConcept		imgregrole:businessUse .

imgregrole:cropping
	rdf:type skos:Concept ;
	skos:prefLabel	"cropping"@en-GB ;
	skos:definition	"Image region can be used for any cropping"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:recomCropping
	rdf:type skos:Concept ;
	skos:prefLabel	"recommended cropping"@en-GB ;
	skos:definition	"Image region is recommended for cropping"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:landscapeCropping
	rdf:type skos:Concept ;
	skos:prefLabel	"landscape format cropping"@en-GB ;
	skos:definition	"Image region suggested for cropping in landscape format"@en-GB ;
	skos:note	"Use for images of non-landscape format"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:portraitCropping
	rdf:type skos:Concept ;
	skos:prefLabel	"portrait format cropping"@en-GB ;
	skos:definition	"Image region suggested for cropping in portrait format"@en-GB ;
	skos:note	"Use for images of non-portrait format"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:squareCropping
	rdf:type skos:Concept ;
	skos:prefLabel	"square format cropping"@en-GB ;
	skos:definition	"Image region suggested for cropping in square format"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:compositeImageItem
	rdf:type skos:Concept ;
	skos:prefLabel	"composite image item"@en-GB ;
	skos:definition	"Image region of an item in a composite image"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:copyrightRegion
	rdf:type skos:Concept ;
	skos:prefLabel	"copyright region"@en-GB ;
	skos:definition	"Image region with a copyright different from the copyright of the whole picture"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:subjectArea
	rdf:type skos:Concept ;
	skos:prefLabel	"subject area"@en-GB ;
	skos:definition	"Image region contains a subject in the overall scene."@en-GB ;
	skos:note	"Multiple regions of an image may be set as subject area."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:mainSubjectArea
	rdf:type skos:Concept ;
	skos:prefLabel	"main subject area"@en-GB ;
	skos:definition	"Image region contains the main subject in the overall scene. Same as the Exif SubjectArea."@en-GB ;
	skos:note	"Only a single region of an image may be set as main subject area."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:areaOfInterest
	rdf:type skos:Concept ;
	skos:prefLabel	"area of interest"@en-GB ;
	skos:definition	"Image region contains a thing of special interest to the viewer"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:anonymised
	rdf:type skos:Concept ;
	skos:prefLabel	"anonymised"@en-GB ;
	skos:definition	"Image region obfuscates a person or object which should not be identifiable by this image"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2025-03-31T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2025-03-31T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2025-03-31T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2025-03-31T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:recommendedAnonymisation
	rdf:type skos:Concept ;
	skos:prefLabel	"recommended anonymisation"@en-GB ;
	skos:definition	"Image Region should obfuscate a person or object which should not be identifiable by this image in an upcoming workflow step"@en-GB ;
	skos:note	"Obfuscation may be required for protecting privacy, security, or for legal reasons before making an image public."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2025-03-31T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2025-03-31T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2025-03-31T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2025-03-31T12:00:00+00:00"^^xsd:dateTime  .

imgregrole:businessUse
	rdf:type skos:Concept ;
	skos:prefLabel	"business use"@en-GB ;
	skos:definition	"Image region is dedicated to a specific business use"@en-GB ;
	skos:note	"In addition a more granular role could be expressed by a term of a role CV of this business."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/imageregionrole/>  ;
	ikos:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-12-06T12:00:00+00:00"^^xsd:dateTime  .
