aspfacet:ageclass
	rdf:type skos:Concept ;
	skos:prefLabel	"age class"@en-GB ;
	skos:definition	"The age range of a competition"@en-GB ;
	skos:note	"This facet can be applied to any Media Topic that is a child or grandchild of a sport competition discipline (medtop:20000822). This facet can take a string or scalar value."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/asportfacet/>  ;
	ikos:created "2017-05-04T14:00:00+00:00"^^xsd:dateTime ;
