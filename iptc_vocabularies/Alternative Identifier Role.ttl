altidrole:pmdImgGUID
	rdf:type skos:Concept ;
	skos:prefLabel	"Image GUID (IPTC Photo Metadata)"@en-GB ;
	skos:definition	"Globally Unique Identifier of an image as specified by the IPTC Photo Metadata"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/altidrole/>  ;
	ikos:created "2017-12-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2017-12-04T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2017-12-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2017-12-04T12:00:00+00:00"^^xsd:dateTime  .

altidrole:pmdImgSupplierImgId
	rdf:type skos:Concept ;
	skos:prefLabel	"Image Supplier's Image ID (IPTC Photo Metadata)"@en-GB ;
	skos:definition	"Identifier of an image issued by a supplier of this image as specified by the IPTC Photo Metadata"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/altidrole/>  ;
	ikos:created "2017-12-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2017-12-04T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2017-12-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2017-12-04T12:00:00+00:00"^^xsd:dateTime  .

altidrole:pmdJobId
	rdf:type skos:Concept ;
	skos:prefLabel	"Job ID (IPTC Photo Metadata)"@en-GB ;
	skos:definition	"A job identifier as specified by the IPTC Photo Metadata."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/altidrole/>  ;
	ikos:created "2017-12-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2017-12-04T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2017-12-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2017-12-04T12:00:00+00:00"^^xsd:dateTime  .

altidrole:vmhVideoId
	rdf:type skos:Concept ;
	skos:prefLabel	"IPTC Video Metadata Hub ID"@en-GB ;
	skos:definition	"An identifier as specified by the IPTC Video Metadata Hub standard."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/altidrole/>  ;
