<http://cv.iptc.org/newscodes/digitalsourcetype/> 
	rdf:type skos:ConceptScheme ; 
  ikos:prefSchemeAlias "digsrctype" ;
  ikos:authority "http://www.iptc.org" ;
  dct:rightsHolder "IPTC, International Press Telecommunications Council - https://iptc.org" ;
  ikos:licenceLink "http://creativecommons.org/licenses/by/4.0/" ;
  ikos:dateReleased "2024-10-23T12:00:00+00:00"^^xsd:dateTime ;
  dct:dateSubmitted "2024-10-23T12:00:00+00:00"^^xsd:dateTime ;
  skos:prefLabel "Digital Source Type"@en-GB ;
  skos:definition "Indicates from which source a digital image was created."@en-GB ;
	skos:hasTopConcept		digsrctype:digitalCapture ;
	skos:hasTopConcept		digsrctype:computationalCapture ;
	skos:hasTopConcept		digsrctype:negativeFilm ;
	skos:hasTopConcept		digsrctype:positiveFilm ;
	skos:hasTopConcept		digsrctype:print ;
	skos:hasTopConcept		digsrctype:minorHumanEdits ;
	skos:hasTopConcept		digsrctype:humanEdits ;
	skos:hasTopConcept		digsrctype:compositeWithTrainedAlgorithmicMedia ;
	skos:hasTopConcept		digsrctype:algorithmicallyEnhanced ;
	skos:hasTopConcept		digsrctype:softwareImage ;
	skos:hasTopConcept		digsrctype:digitalArt ;
	skos:hasTopConcept		digsrctype:digitalCreation ;
	skos:hasTopConcept		digsrctype:dataDrivenMedia ;
	skos:hasTopConcept		digsrctype:trainedAlgorithmicMedia ;
	skos:hasTopConcept		digsrctype:algorithmicMedia ;
	skos:hasTopConcept		digsrctype:screenCapture ;
	skos:hasTopConcept		digsrctype:virtualRecording ;
	skos:hasTopConcept		digsrctype:composite ;
	skos:hasTopConcept		digsrctype:compositeCapture ;
	skos:hasTopConcept		digsrctype:compositeSynthetic .

digsrctype:digitalCapture
	rdf:type skos:Concept ;
	skos:prefLabel	"Digital capture sampled from real life"@en-GB ;
	skos:definition	"The media was captured from a real-life source using a digital camera or digital recording device"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2008-01-01T01:00:00+00:00"^^xsd:dateTime ;
	dct:created "2008-01-01T01:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:computationalCapture
	rdf:type skos:Concept ;
	skos:prefLabel	"Multi-frame computational capture sampled from real life"@en-GB ;
	skos:definition	"The media is the result of capturing multiple frames from a real-life source using a digital camera or digital recording device, then automatically merging them into a single frame using digital signal processing techniques and/or non-generative AI. Includes High Dynamic Range (HDR) processing common in smartphone camera apps."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:negativeFilm
	rdf:type skos:Concept ;
	skos:prefLabel	"Digitised from a transparent negative"@en-GB ;
	skos:definition	"The media was digitised from a negative on film or other transparent medium"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2008-01-01T01:00:00+00:00"^^xsd:dateTime ;
	dct:created "2008-01-01T01:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-09-26T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-09-26T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:positiveFilm
	rdf:type skos:Concept ;
	skos:prefLabel	"Digitised from a transparent positive"@en-GB ;
	skos:definition	"The media was digitised from a positive on a transparency or other transparent medium"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2008-01-01T01:00:00+00:00"^^xsd:dateTime ;
	dct:created "2008-01-01T01:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-09-26T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-09-26T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:print
	rdf:type skos:Concept ;
	skos:prefLabel	"Digitised from a non-transparent medium"@en-GB ;
	skos:definition	"The media was digitised from a non-transparent medium such as a photographic print"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2008-01-01T01:00:00+00:00"^^xsd:dateTime ;
	dct:created "2008-01-01T01:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:minorHumanEdits
	rdf:type skos:Concept ;
	skos:prefLabel	"Original media with minor human edits"@en-GB ;
	skos:definition	"Minor augmentation or correction by a human, such as a digitally-retouched photo used in a magazine"@en-GB ;
	skos:note	"Retired. Use *humanEdits* instead."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime  ; 
	ikos:retired "2024-09-17T12:00:00+00:00"^^xsd:dateTime .

digsrctype:humanEdits
	rdf:type skos:Concept ;
	skos:prefLabel	"Human-edited media"@en-GB ;
	skos:definition	"Augmentation, correction or enhancement by one or more humans using non-generative tools"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:compositeWithTrainedAlgorithmicMedia
	rdf:type skos:Concept ;
	skos:prefLabel	"Edited using Generative AI"@en-GB ;
	skos:definition	"Augmentation, correction or enhancement using a Generative AI model, such as with inpainting or outpainting operations"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2023-07-26T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2023-07-26T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:algorithmicallyEnhanced
	rdf:type skos:Concept ;
	skos:prefLabel	"Algorithmically-altered media"@en-GB ;
	skos:definition	"Modification or correction by algorithm without changing the main content of the media, initiated or configured by a human, such as sharpening or applying noise reduction"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-10-23T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-10-23T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:softwareImage
	rdf:type skos:Concept ;
	skos:prefLabel	"Created by software"@en-GB ;
	skos:definition	"The digital image was created by computer software"@en-GB ;
	skos:note	"Retired in June 2022. Use more specific terms instead."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2008-01-01T01:00:00+00:00"^^xsd:dateTime ;
	dct:created "2008-01-01T01:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2022-06-14T12:00:00+00:00"^^xsd:dateTime  ; 
	ikos:retired "2022-06-14T12:00:00+00:00"^^xsd:dateTime .

digsrctype:digitalArt
	rdf:type skos:Concept ;
	skos:prefLabel	"Digital art"@en-GB ;
	skos:definition	"Media created by a human using digital tools"@en-GB ;
	skos:note	"Retired. Use *digitalCreation* instead."@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2022-06-14T12:00:00+00:00"^^xsd:dateTime  ; 
	ikos:retired "2024-09-17T12:00:00+00:00"^^xsd:dateTime .

digsrctype:digitalCreation
	rdf:type skos:Concept ;
	skos:prefLabel	"Digital creation"@en-GB ;
	skos:definition	"Media created by a human using non-generative tools"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:dataDrivenMedia
	rdf:type skos:Concept ;
	skos:prefLabel	"Data-driven media"@en-GB ;
	skos:definition	"Digital media representation of data via human programming or creativity"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2022-06-14T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:trainedAlgorithmicMedia
	rdf:type skos:Concept ;
	skos:prefLabel	"Created using Generative AI"@en-GB ;
	skos:definition	"Digital media created algorithmically using an Artificial Intelligence model trained on captured content"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-10-23T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-10-23T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:algorithmicMedia
	rdf:type skos:Concept ;
	skos:prefLabel	"Pure algorithmic media"@en-GB ;
	skos:definition	"Media created purely by an algorithm not based on any sampled training data, e.g. an image created by software using a mathematical formula"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2022-06-14T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2022-06-14T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:screenCapture
	rdf:type skos:Concept ;
	skos:prefLabel	"Screen capture"@en-GB ;
	skos:definition	"A capture of the contents of the screen of a computer or mobile device"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
	ikos:created "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-09-17T12:00:00+00:00"^^xsd:dateTime  .

digsrctype:virtualRecording
	rdf:type skos:Concept ;
	skos:prefLabel	"Virtual event recording"@en-GB ;
	skos:definition	"Live recording of virtual event based on Generative AI and/or captured elements"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/digitalsourcetype/>  ;
