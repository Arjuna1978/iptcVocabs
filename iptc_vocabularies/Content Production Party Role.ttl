cpprole:mediaOffice
	rdf:type skos:Concept ;
	skos:prefLabel	"Media Office"@en-GB ;
	skos:definition	"The media relationships office of a person, organisation or company"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
