<http://cv.iptc.org/newscodes/contentprodpartyrole/> 
	rdf:type skos:ConceptScheme ; 
  ikos:prefSchemeAlias "cpprole" ;
  ikos:authority "http://www.iptc.org" ;
  dct:rightsHolder "IPTC, International Press Telecommunications Council - https://iptc.org" ;
  ikos:licenceLink "http://creativecommons.org/licenses/by/4.0/" ;
  ikos:dateReleased "2024-02-13T12:00:00+00:00"^^xsd:dateTime ;
  dct:dateSubmitted "2024-02-13T12:00:00+00:00"^^xsd:dateTime ;
  skos:prefLabel "Content Production Party Role"@en-GB ;
  skos:definition "The role of a party (person, organisation or system) which created, originated, supplied, enhanced, distributed or contributed in another way to the content, or the role of a party which supported these activities."@en-GB ;
	skos:hasTopConcept		cpprole:author ;
	skos:hasTopConcept		cpprole:cameraOperator ;
	skos:hasTopConcept		cpprole:contentEditor ;
	skos:hasTopConcept		cpprole:contentSource ;
	skos:hasTopConcept		cpprole:correspondent ;
	skos:hasTopConcept		cpprole:descrWriter ;
	skos:hasTopConcept		cpprole:distributor ;
	skos:hasTopConcept		cpprole:editor ;
	skos:hasTopConcept		cpprole:factChecker ;
	skos:hasTopConcept		cpprole:genAIPromptWriter ;
	skos:hasTopConcept		cpprole:imgSupplier ;
	skos:hasTopConcept		cpprole:interviewee ;
	skos:hasTopConcept		cpprole:mediaOffice ;
	skos:hasTopConcept		cpprole:metadataEditor ;
	skos:hasTopConcept		cpprole:origcont ;
	skos:hasTopConcept		cpprole:originfo ;
	skos:hasTopConcept		cpprole:producer ;
	skos:hasTopConcept		cpprole:spokesperson .

cpprole:author
	rdf:type skos:Concept ;
	skos:prefLabel	"Author"@en-GB ;
	skos:definition	"A party (person, organisation or system) that created the content"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2021-02-18T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2021-02-18T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-02-13T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-02-13T12:00:00+00:00"^^xsd:dateTime  .

cpprole:cameraOperator
	rdf:type skos:Concept ;
	skos:prefLabel	"Camera Operator"@en-GB ;
	skos:definition	"A party (person, organisation or system) who operates the camera that records the content of the item"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2018-04-04T12:00:00+00:00"^^xsd:dateTime  .

cpprole:contentEditor
	rdf:type skos:Concept ;
	skos:prefLabel	"Content Editor"@en-GB ;
	skos:definition	"A party (person, organisation or system) that edited the content of the item"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2023-09-29T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2023-09-29T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2023-09-29T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2023-09-29T12:00:00+00:00"^^xsd:dateTime  .

cpprole:contentSource
	rdf:type skos:Concept ;
	skos:prefLabel	"Content Source"@en-GB ;
	skos:definition	"A party (person, organisation or system) that contributed to the content of the item as a source"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2018-04-04T12:00:00+00:00"^^xsd:dateTime  .

cpprole:correspondent
	rdf:type skos:Concept ;
	skos:prefLabel	"Correspondent"@en-GB ;
	skos:definition	"A party (person, organisation or system) that is reporting information that contributes to the content of the item"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2018-04-04T12:00:00+00:00"^^xsd:dateTime  .

cpprole:descrWriter
	rdf:type skos:Concept ;
	skos:prefLabel	"Description Writer"@en-GB ;
	skos:definition	"A party (person, organisation or system) editing the description of content"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2018-04-04T12:00:00+00:00"^^xsd:dateTime  .

cpprole:distributor
	rdf:type skos:Concept ;
	skos:prefLabel	"Distributor"@en-GB ;
	skos:definition	"A party (person, organisation or system)that distributed an item"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2023-03-30T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2023-03-30T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2023-03-30T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2023-03-30T12:00:00+00:00"^^xsd:dateTime  .

cpprole:editor
	rdf:type skos:Concept ;
	skos:prefLabel	"Editor"@en-GB ;
	skos:definition	"A party (person, organisation or system) editing the content and/or metadata of the item"@en-GB ;
	skos:note	"To specify an editor of only the content or only the metadata of an item, please use the more specific contentEditor or metadataEditor terms"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2019-10-12T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2019-10-12T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2019-10-12T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2019-10-12T12:00:00+00:00"^^xsd:dateTime  .

cpprole:factChecker
	rdf:type skos:Concept ;
	skos:prefLabel	"Fact Checker"@en-GB ;
	skos:definition	"Specifies the party (person, organisation or system) that fact-checked the news item to ensure its accuracy"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2021-02-18T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2021-02-18T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2021-02-18T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2021-02-18T12:00:00+00:00"^^xsd:dateTime  .

cpprole:genAIPromptWriter
	rdf:type skos:Concept ;
	skos:prefLabel	"Generative AI Prompt Writer"@en-GB ;
	skos:definition	"A party (person, organisation, or system) that wrote or edited the prompt entered into a generative AI system"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2024-03-28T12:00:00+00:00"^^xsd:dateTime ;
	dct:created "2024-03-28T12:00:00+00:00"^^xsd:dateTime ;
	ikos:modified "2024-03-28T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2024-03-28T12:00:00+00:00"^^xsd:dateTime  .

cpprole:imgSupplier
	rdf:type skos:Concept ;
	skos:prefLabel	"Image Supplier"@en-GB ;
	skos:definition	"A party (person, organisation or system) that supplied an image as content of the item"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
