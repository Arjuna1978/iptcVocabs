cpprole:metadataEditor
	rdf:type skos:Concept ;
	skos:prefLabel	"Metadata Editor"@en-GB ;
	skos:definition	"A party (person, organisation or system) that edited the metadata of the item"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2023-09-29T12:00:00+00:00"^^xsd:dateTime ;
