	ikos:modified "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
	dct:modified "2018-04-04T12:00:00+00:00"^^xsd:dateTime  .

cpprole:interviewee
	rdf:type skos:Concept ;
	skos:prefLabel	"Interviewee"@en-GB ;
	skos:definition	"A person being interviewed for the item"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
