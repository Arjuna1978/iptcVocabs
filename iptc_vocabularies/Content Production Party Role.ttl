cpprole:originfo
	rdf:type skos:Concept ;
	skos:prefLabel	"Information Originator"@en-GB ;
	skos:definition	"A party (person, organisation or systenm) which provided some information, such as metadata, used to create or enhance the content of the item"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2018-04-04T12:00:00+00:00"^^xsd:dateTime ;
