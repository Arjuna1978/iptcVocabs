cpprole:producer
	rdf:type skos:Concept ;
	skos:prefLabel	"Producer"@en-GB ;
	skos:definition	"A party (person, organisation or system) that curates and manages the creation of content"@en-GB ;
	skos:inScheme <http://cv.iptc.org/newscodes/contentprodpartyrole/>  ;
	ikos:created "2024-02-13T12:00:00+00:00"^^xsd:dateTime ;
